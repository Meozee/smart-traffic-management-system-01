# ═══════════════════════════════════════════════════════════════════════════════
# GITIGNORE — Smart Traffic Monitoring System
# ═══════════════════════════════════════════════════════════════════════════════
# Exclude sensitive, large, dan generated files dari version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT & CONFIGURATION (SENSITIVE)
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.development

# ─────────────────────────────────────────────────────────────────────────────
# PYTHON
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ─────────────────────────────────────────────────────────────────────────────
# VIRTUAL ENVIRONMENTS
# ─────────────────────────────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ─────────────────────────────────────────────────────────────────────────────
# IDE & EDITOR
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace
.vim/
.netrwhist

# ─────────────────────────────────────────────────────────────────────────────
# MODEL WEIGHTS & LARGE FILES
# ─────────────────────────────────────────────────────────────────────────────
*.pt
*.pth
*.onnx
*.h5
*.pkl
*.joblib

# ─────────────────────────────────────────────────────────────────────────────
# VIDEO & MEDIA FILES
# ─────────────────────────────────────────────────────────────────────────────
*.mp4
*.avi
*.mov
*.mkv
*.webm
*.flv
*.m3u8
*.ts

# ─────────────────────────────────────────────────────────────────────────────
# LOGS & DEBUG
# ─────────────────────────────────────────────────────────────────────────────
*.log
*.log.*
logs/
debug/
*.dump

# ─────────────────────────────────────────────────────────────────────────────
# PYTEST & TESTING
# ─────────────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.hypothesis/

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
data.sql
dump.sql

# ─────────────────────────────────────────────────────────────────────────────
# DOCKER
# ─────────────────────────────────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ─────────────────────────────────────────────────────────────────────────────
# OS SPECIFIC
# ─────────────────────────────────────────────────────────────────────────────
Thumbs.db
.AppleDouble
.LSOverride
._*

# ─────────────────────────────────────────────────────────────────────────────
# BUILD ARTIFACTS
# ─────────────────────────────────────────────────────────────────────────────
build/
dist/
*.egg-info/
.eggs/

# ─────────────────────────────────────────────────────────────────────────────
# TEMPORARY FILES
# ─────────────────────────────────────────────────────────────────────────────
*.tmp
*.temp
*.bak
*.backup
*~