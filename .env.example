# STMS Example Environment Variables
# Rename this file to .env and update values before deployment.

# PostgreSQL database credentials for Docker Compose
POSTGRES_USER=stms_user
POSTGRES_PASSWORD=stms_password
POSTGRES_DB=stms_db

# PostgreSQL connection string used by the backend
DATABASE_URL=postgresql://stms_user:stms_password@db:5432/stms_db

# JWT / security settings
SECRET_KEY=replace-with-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# YOLOv8 model and detection thresholds
MODEL_PATH=/app/yolov8n.pt
CONFIDENCE_THRESHOLD=0.5
DENSITY_LOW_THRESHOLD=40
DENSITY_HIGH_THRESHOLD=70

# Background job configuration
DENSITY_INTERVAL_MINUTES=15
DASHBOARD_POLL_INTERVAL_MS=5000

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Internal API key for internal CV/backend communication
INTERNAL_API_KEY=stms-internal-key-2025
